{
    "productName": "MyMusic",
    "version": "0.1.0",
    "identifier": "my-music",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "height": 800,
                "minHeight": 800,
                "minWidth": 1366,
                "resizable": true,
                "title": "MyMusic",
                "width": 1366,
                "transparent": true,
                "decorations": false
            }
        ],
        "security": {
            "csp": "default-src 'self' http://localhost:5173; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: musiclocal: https: http://127.0.0.1:* http://localhost:*; media-src 'self' musiclocal: blob: data: https: http: http://127.0.0.1:* http://localhost:*; connect-src 'self' musiclocal: https: http: http://127.0.0.1:* http://localhost:*;"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "installMode": "both",
                "displayLanguageSelector": true
            }
        }
    }
}